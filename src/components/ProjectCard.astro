---
interface Props {
  title: string;
  description: string;
  status: string;
  href: string;
}

const { title, description, status, href } = Astro.props;

const statusStyle =
  status === 'Beta'
    ? 'bg-accent-light text-accent'
    : 'bg-border text-ink-muted';
---

<a href={href} class="group block bg-surface border border-border p-8 hover:border-ink-muted transition-colors duration-200">
  <div class="flex items-start justify-between mb-4">
    <h3 class="font-display font-semibold text-2xl text-ink group-hover:text-accent transition-colors duration-200">
      {title}
    </h3>
    <span class={`text-xs font-medium px-2.5 py-0.5 rounded-full shrink-0 ml-4 mt-1 ${statusStyle}`}>
      {status}
    </span>
  </div>

  <p class="text-sm text-ink-muted leading-relaxed mb-6">
    {description}
  </p>

  <span class="text-xs font-medium text-accent group-hover:text-ink transition-colors duration-200">
    View project &rarr;
  </span>
</a>
