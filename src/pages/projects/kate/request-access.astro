---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Request Access — Kate"
  description="Request early access to Kate, an AI coaching agent for senior executives in active job search."
>
  <div class="mx-auto max-w-6xl px-6 py-16 md:px-10 md:py-24">
    <a
      href="/projects/kate"
      class="mb-12 inline-flex items-center text-xs font-bold text-ink-muted transition-colors duration-150 hover:text-ink"
    >
      &larr; Back to Kate
    </a>

    <header class="mb-12 max-w-xl">
      <h1 class="mb-4 font-display text-5xl font-semibold leading-none text-ink md:text-7xl">
        Request Access
      </h1>
      <p class="text-lg leading-relaxed text-ink-muted">
        Kate is currently in private beta. Fill out the form below and we'll be in touch.
      </p>
    </header>

    <div class="max-w-2xl">
      <div style="width:100%;height:500px;" data-fillout-id="xqTFiC1DQeus" data-fillout-embed-type="standard" data-fillout-inherit-parameters data-fillout-dynamic-resize></div><script src="https://server.fillout.com/embed/v1/"></script>
    </div>
  </div>
</BaseLayout>

