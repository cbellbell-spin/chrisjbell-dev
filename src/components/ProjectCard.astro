---
import StatusPill from './StatusPill.astro';

interface Props {
  title: string;
  description: string;
  status: string;
  href: string;
}

const { title, description, status, href } = Astro.props;
---

<a
  href={href}
  class="group flex min-h-72 flex-col justify-between rounded-[8px] border border-border bg-surface p-7 transition-colors duration-150 hover:border-accent"
>
  <div>
    <div class="mb-5 flex items-start justify-between gap-4">
      <h3 class="font-display text-4xl font-semibold leading-none text-ink transition-colors duration-150 group-hover:text-accent">
        {title}
      </h3>
      <StatusPill status={status} />
    </div>

    <p class="text-sm leading-relaxed text-ink-muted">
      {description}
    </p>
  </div>

  <span class="mt-8 text-sm font-bold text-accent transition-colors duration-150 group-hover:text-ink">
    View project &rarr;
  </span>
</a>
