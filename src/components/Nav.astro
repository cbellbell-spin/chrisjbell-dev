---
const navLinks = [
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
];

const currentPath = Astro.url.pathname;
---

<nav class="flex items-center justify-between gap-6 py-5">
  <a
    href="/"
    class="font-display text-[1.35rem] font-semibold leading-none text-ink hover:text-accent transition-colors duration-150"
  >
    Chris J. Bell
  </a>

  <ul class="flex items-center gap-5 md:gap-8" role="list">
    {navLinks.map(({ href, label }) => (
      <li>
        <a
          href={href}
          class={`text-sm transition-colors duration-150 ${
            currentPath.startsWith(href)
              ? 'text-accent font-semibold'
              : 'text-ink-muted hover:text-ink'
          }`}
        >
          {label}
        </a>
      </li>
    ))}
  </ul>
</nav>
