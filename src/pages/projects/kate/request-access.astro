---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Request Access — Kate"
  description="Request early access to Kate, an AI coaching agent for senior executives in active job search."
>
  <div class="py-16 md:py-24">
    <a
      href="/projects/kate"
      class="inline-flex items-center text-xs text-ink-muted hover:text-ink transition-colors duration-150 mb-12"
    >
      &larr; Back to Kate
    </a>

    <header class="mb-12 max-w-xl">
      <h1 class="font-display font-bold text-4xl md:text-5xl text-ink tracking-display mb-4">
        Request Access
      </h1>
      <p class="text-lg text-ink-muted leading-relaxed">
        Kate is currently in private beta. Fill out the form below and we'll be in touch.
      </p>
    </header>

    <div class="max-w-2xl">
      <div data-tf-live="01KKDCN07K8DBXFGPBSXM4359S"></div>
    </div>
  </div>
</BaseLayout>

<script is:inline src="//embed.typeform.com/next/embed.js"></script>
