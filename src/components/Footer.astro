---
const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-bg">
  <div class="max-w-6xl mx-auto px-6 md:px-10">
    <div class="flex flex-col gap-3 py-8 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-xs text-ink-muted">
        &copy; {year} Chris J. Bell
      </p>
      <a
        href="/legal/privacy-policy"
        class="text-xs text-ink-muted hover:text-ink transition-colors duration-150"
      >
        Privacy Policy
      </a>
    </div>
  </div>
</footer>
